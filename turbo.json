{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalDependencies": [".env", ".env.local"],
  "globalPassThroughEnv": ["PATH", "HOME", "USER", "LANG", "LC_ALL"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".output/**"],
      "env": ["DATABASE_URL", "AUTH_SECRET", "GOOGLE_API_KEY", "GEMINI_MODEL", "OCR_WORKER_URL"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "inputs": ["$TURBO_DEFAULT$", "biome.jsonc", "ruff.toml"]
    },
    "format": {
      "dependsOn": ["^format"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "env": [
        "DATABASE_URL",
        "CLOUDFLARE_ACCOUNT_ID",
        "S3_ACCESS_KEY_ID",
        "S3_SECRET_ACCESS_KEY",
        "S3_BUCKET_NAME",
        "S3_ENDPOINT",
        "GOOGLE_API_KEY",
        "GEMINI_MODEL",
        "OCR_WORKER_URL",
        "VITE_API_BASE_URL",
        "RUST_LOG",
        "PORT",
        "API_PORT"
      ]
    }
  }
}
