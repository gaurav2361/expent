# Core
DATABASE_URL=postgresql://user:pass@host:port/dbname
AUTH_SECRET=your-secret-at-least-32-chars-long

# Rust Server (apps/server) - Port 3001
PORT=3001
AUTH_BASE_URL=http://localhost:3001
RUST_LOG=info

# Hono Backend (apps/backend) - Port 8000
# (Currently used for R2 presigned URLs)
R2_ENDPOINT=https:// <accountid >.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=expent-uploads
OCR_WORKER_URL=http://localhost:8001/process

# Python OCR Worker (apps/ocr-worker) - Port 8001
# No specific envs for now, runs on port 8001

# Web Frontend (apps/web) - Port 3000
VITE_AUTH_BASE_URL=http://localhost:3001
VITE_API_BASE_URL=http://localhost:8000
