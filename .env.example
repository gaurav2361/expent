# Core
DATABASE_URL=postgresql://user:pass@host:port/dbname
AUTH_SECRET=your-secret-at-least-32-chars-long

# Cloudflare / S3
CLOUDFLARE_ACCOUNT_ID=cb58454566374785b8964fb26742b69b
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
S3_BUCKET_NAME=myuserprofilepicture
S3_ENDPOINT=https://cb58454566374785b8964fb26742b69b.r2.cloudflarestorage.com

# Rust Server (apps/server) - Port 3001
PORT=3001
AUTH_BASE_URL=http://localhost:3001
RUST_LOG=info

# Python OCR Worker (apps/ocr-worker) - Port 8001
# OCR_WORKER_URL=http://localhost:8001/process (Used by Server to call Worker)
OCR_WORKER_URL=http://localhost:8001/process

# Web Frontend (apps/web) - Port 3000
VITE_AUTH_BASE_URL=http://localhost:3001
VITE_API_BASE_URL=http://localhost:3001
