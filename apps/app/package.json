{
  "name": "@expent/app",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "main": "expo-router/entry",
  "scripts": {
    "dev-no": "run-emulator && expo run:android",
    "android": "expo start -c --android",
    "ios": "expo start -c --ios",
    "web": "expo start -c --web",
    "clean": "rm -rf .expo node_modules",
    "start": "expo start",
    "prebuild": "expo prebuild",
    "emulator": "run-emulator",
    "xcode": "xed -b ios",
    "doctor": "npx expo-doctor@latest",
    "start:preview": "cross-env EXPO_PUBLIC_APP_ENV=preview pnpm run start",
    "prebuild:preview": "cross-env EXPO_PUBLIC_APP_ENV=preview STRICT_ENV_VALIDATION=1 pnpm run prebuild",
    "prebuild:development": "cross-env EXPO_PUBLIC_APP_ENV=development STRICT_ENV_VALIDATION=1 pnpm run prebuild",
    "android:preview": "cross-env EXPO_PUBLIC_APP_ENV=preview pnpm run android",
    "ios:preview": "cross-env EXPO_PUBLIC_APP_ENV=preview pnpm run ios",
    "start:production": "cross-env EXPO_PUBLIC_APP_ENV=production pnpm run start",
    "prebuild:production": "cross-env EXPO_PUBLIC_APP_ENV=production STRICT_ENV_VALIDATION=1 pnpm run prebuild",
    "android:production": "cross-env EXPO_PUBLIC_APP_ENV=production pnpm run android",
    "ios:production": "cross-env EXPO_PUBLIC_APP_ENV=production pnpm run ios",
    "build:development:ios": "eas build --profile development --platform ios",
    "build:development:android": "eas build --profile development --platform android",
    "build:preview:ios": "eas build --profile preview --platform ios",
    "build:preview:android": "eas build --profile preview --platform android",
    "build:production:ios": "eas build --profile production --platform ios",
    "build:production:android": "eas build --profile production --platform android",
    "app-release": "cross-env SKIP_BRANCH_PROTECTION=true np --no-publish --no-cleanup --no-release-draft",
    "type-check": "tsc --noemit",
    "test": "jest",
    "check-all": "pnpm run type-check && pnpm run test",
    "test:ci": "pnpm run test --coverage",
    "test:watch": "pnpm run test --watch"
  },
  "dependencies": {
    "@expent/types": "workspace:*",
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/metro-runtime": "^6.1.2",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@react-navigation/native": "^7.0.0",
    "@rn-primitives/accordion": "^1.4.0",
    "@rn-primitives/alert-dialog": "^1.4.0",
    "@rn-primitives/aspect-ratio": "^1.4.0",
    "@rn-primitives/avatar": "^1.4.0",
    "@rn-primitives/checkbox": "^1.4.0",
    "@rn-primitives/collapsible": "^1.4.0",
    "@rn-primitives/context-menu": "^1.4.0",
    "@rn-primitives/dialog": "^1.4.0",
    "@rn-primitives/dropdown-menu": "^1.4.0",
    "@rn-primitives/hover-card": "^1.4.0",
    "@rn-primitives/label": "^1.4.0",
    "@rn-primitives/menubar": "^1.4.0",
    "@rn-primitives/popover": "^1.4.0",
    "@rn-primitives/portal": "~1.4.0",
    "@rn-primitives/progress": "^1.4.0",
    "@rn-primitives/radio-group": "^1.4.0",
    "@rn-primitives/select": "^1.4.0",
    "@rn-primitives/separator": "^1.4.0",
    "@rn-primitives/slot": "^1.4.0",
    "@rn-primitives/switch": "^1.4.0",
    "@rn-primitives/tabs": "^1.4.0",
    "@rn-primitives/toggle": "^1.4.0",
    "@rn-primitives/toggle-group": "^1.4.0",
    "@rn-primitives/tooltip": "^1.4.0",
    "@shopify/flash-list": "2.0.2",
    "@tanstack/react-query": "^5.90.19",
    "app-icon-badge": "^0.1.2",
    "axios": "^1.13.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "expo": "~55.0.9",
    "expo-constants": "~55.0.9",
    "expo-crypto": "^15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-font": "~14.0.11",
    "expo-haptics": "~55.0.9",
    "expo-image": "~3.0.11",
    "expo-linking": "~55.0.9",
    "expo-router": "~55.0.8",
    "expo-splash-screen": "~55.0.13",
    "expo-status-bar": "~55.0.4",
    "expo-system-ui": "~55.0.11",
    "expo-updates": "~55.0.16",
    "lucide-react-native": "^0.545.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-error-boundary": "^6.1.0",
    "react-native": "0.83.4",
    "react-native-edge-to-edge": "^1.7.0",
    "react-native-flash-message": "^0.4.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-keyboard-controller": "1.20.7",
    "react-native-mmkv": "~4.1.1",
    "react-native-nitro-modules": "^0.33.2",
    "react-native-reanimated": "4.2.1",
    "react-native-restart": "0.0.27",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.2",
    "tailwind-merge": "^3.5.0",
    "uniwind": "^1.5.0",
    "zod": "^4.3.5",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@dev-plugins/react-query": "^0.4.0",
    "@expo/config": "~12.0.13",
    "@tailwindcss/cli": "^4.0.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/invariant": "^2.2.37",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.10",
    "babel-plugin-module-resolver": "^5.0.2",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.0",
    "jest-junit": "^16.0.0",
    "lint-staged": "^16.2.7",
    "np": "^10.3.0",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2"
  }
}
