{
  "name": "expent",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "dotenv -- turbo build",
    "dev": "dotenv -- turbo dev",
    "check": "biome check --no-errors-on-unmatched --files-ignore-unknown=true",
    "lint": "biome lint --write --no-errors-on-unmatched",
    "format": "biome format --write --no-errors-on-unmatched",
    "typecheck": "dotenv -- turbo typecheck",
    "format-all": "cargo fmt && uv format && pnpm format",
    "app": "pnpm --filter @expent/app",
    "app:dev": "pnpm --filter @expent/app dev",
    "app:ios": "pnpm --filter @expent/app ios",
    "app:android": "pnpm --filter @expent/app android"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "dotenv-cli": "^11.0.0",
    "turbo": "^2.9.3",
    "typescript": "6.0.2"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24"
  }
}
